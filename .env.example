# Copy this file to .env and fill in your values

# Required for AI journal generation (Claude API)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Binance API credentials (only needed for private endpoints)
# Public market data endpoints work without authentication
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_RETRIES=1

# Optional: CoinGlass API key for real aggregated derivatives data
# (funding rates, open interest, liquidations across all exchanges)
# Free tier available at: https://coinglass.com/pricing
COINGLASS_API_KEY=your_coinglass_key_here

# Telegram daily trade notifications (sent at 8AM SGT every day)
# 1. Create a bot via @BotFather → get token
# 2. Create a public channel → add bot as admin with "Post Messages" permission
# 3. Set TELEGRAM_CHAT_ID to @YourChannelUsername
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Public channel: @YourChannelUsername
# Private channel or supergroup: numeric ID (negative number, e.g. -1003529898229)
# Get numeric ID: send a message to the group, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates and look for "chat":{"id":
TELEGRAM_CHAT_ID=@YourChannelUsername

# X (Twitter) daily BTC + ETH 1D signal thread (@EthSayn1560)
# 1. Go to developer.twitter.com → Create Project → Create App
# 2. Set App permissions to "Read and Write"
# 3. Generate Access Token & Secret (under "Keys and tokens")
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_token_secret_here

# Server port (default 8000)
PORT=8000
